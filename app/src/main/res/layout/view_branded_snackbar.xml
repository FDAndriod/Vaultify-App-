<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/branded_snackbar_bg"
    android:paddingStart="14dp"
    android:paddingEnd="18dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Vault brand mark (not launcher / adaptive icon — those still use the stock Android robot foreground). -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/branded_toast_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/vaultifysplashicon" />

    <TextView
        android:id="@+id/branded_toast_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textColor="@android:color/white"
        android:textSize="14sp" />
</LinearLayout>
