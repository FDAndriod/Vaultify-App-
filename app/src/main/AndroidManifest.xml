<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!--
      Required on Android 14+ so the "Select photos" option in the runtime permission dialog
      works. Without it, Android 14 users who pick "Select photos" won't be able to have their
      gallery originals removed after adding to the vault.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".MyApp.MyApplication"
        android:allowBackup="true"
        android:windowSoftInputMode="adjustPan"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vaultify">

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${admobAppId}" />
        <meta-data
            android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id" />
        <meta-data
            android:name="com.facebook.sdk.ClientToken"
            android:value="@string/facebook_client_token" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Vaultify" />
        <activity-alias
            android:name=".MainActivity.Vaultify"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/valtifyicon"
            android:roundIcon="@drawable/valtifyicon"
            android:label="@string/launcher_label_vaultify"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Weather"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/weathericon"
            android:roundIcon="@drawable/weathericon"
            android:label="@string/launcher_label_weather"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Converter"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/convertericon"
            android:roundIcon="@drawable/convertericon"
            android:label="@string/launcher_label_converter"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Music"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/musicicon"
            android:roundIcon="@drawable/musicicon"
            android:label="@string/launcher_label_music"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Calendar"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/calendericon"
            android:roundIcon="@drawable/calendericon"
            android:label="@string/launcher_label_calendar"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Mealio"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/mailoicon"
            android:roundIcon="@drawable/mailoicon"
            android:label="@string/launcher_label_mealio"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Calculator"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/calculatoricon"
            android:roundIcon="@drawable/calculatoricon"
            android:label="@string/launcher_label_calculator"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Notes"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/notesicon"
            android:roundIcon="@drawable/notesicon"
            android:label="@string/launcher_label_notes"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Clock"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/clockicon"
            android:roundIcon="@drawable/clockicon"
            android:label="@string/launcher_label_clock"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Flashlight"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/flashlighticon"
            android:roundIcon="@drawable/flashlighticon"
            android:label="@string/launcher_label_flashlight"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Wallet"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/walleticon"
            android:roundIcon="@drawable/walleticon"
            android:label="@string/launcher_label_wallet"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivity.Fitness"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:icon="@drawable/fitnessicon"
            android:roundIcon="@drawable/fitnessicon"
            android:label="@string/launcher_label_fitness"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>